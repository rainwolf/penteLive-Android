<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="be.submanifold.pentelive"
    android:versionCode="103"
    android:versionName="2.2.5">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" />

    <application
        android:name=".MyApplication"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.AppCompat.Light.NoActionBar">
        <activity
            android:name=".SplashActivity"
            android:clearTaskOnLaunch="true"
            android:screenOrientation="portrait"
            android:theme="@style/SplashTheme">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".LoginActivity"
            android:screenOrientation="portrait" />
        <!-- <activity -->
        <!-- android:name=".MyActivity" -->
        <!-- android:screenOrientation="portrait" /> -->
        <activity
            android:name=".MainActivity"
            android:screenOrientation="portrait" />
        <activity
            android:name=".BoardActivity"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.AppCompat.Light.NoActionBar" />
        <activity
            android:name=".InvitationActivity"
            android:screenOrientation="portrait" />
        <activity
            android:name=".SendMessageActivity"
            android:screenOrientation="portrait" />
        <activity
            android:name=".ReplyMessageActivity"
            android:screenOrientation="portrait" />
        <activity
            android:name=".RegisterActivity"
            android:screenOrientation="portrait" />
        <activity
            android:name=".WebViewActivity"
            android:screenOrientation="portrait" />
        <activity
            android:name=".InviteAIActivity"
            android:screenOrientation="portrait" />
        <activity
            android:name=".MMAIActivity"
            android:screenOrientation="portrait" />
        <activity
            android:name=".KingOfTheHillActivity"
            android:screenOrientation="portrait" />
        <activity
            android:name=".SettingsActivity"
            android:screenOrientation="portrait" />
        <activity
            android:name=".DatabaseActivity"
            android:screenOrientation="portrait" />

        <service android:name=".MyFcmListenerService">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>
        <!-- [START instanceId_listener] -->
        <service android:name=".MyInstanceIDListenerService">
            <intent-filter>
                <action android:name="com.google.firebase.INSTANCE_ID_EVENT" />
            </intent-filter>
        </service>
        <!-- [END instanceId_listener] -->
        <provider
            android:name="android.support.v4.content.FileProvider"
            android:authorities="be.submanifold.pentelive.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <activity
            android:name=".liveGameRoom.LobbyActivity"
            android:screenOrientation="portrait" />
        <activity
            android:name=".liveGameRoom.LiveGameRoomActivity"
            android:screenOrientation="portrait" />
        <activity android:name=".SocialActivity"
            android:screenOrientation="portrait" />
    </application>

</manifest>