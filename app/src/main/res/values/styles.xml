<resources>

<!--     Base application theme. -->
    <style name="AppTheme" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="statusBarScrim">@android:color/background_dark</item>
        <item name="android:textViewStyle">@style/AppTheme.TextView</item>
    </style>

    <!-- Default TextView style. The night variant (res/values-night/styles.xml) adds a
         black halo so white dark-mode text stays legible on any background. -->
    <style name="AppTheme.TextView" parent="Widget.AppCompat.TextView" />

    <style name="AppBarOverlay" parent="ThemeOverlay.AppCompat.Dark.ActionBar" />

    <style name="PopupOverlay" parent="ThemeOverlay.AppCompat.Light" />

    <style name="SplashTheme" parent="Theme.AppCompat.NoActionBar">
        <item name="android:windowBackground">@drawable/background_splash</item>
    </style>

</resources>
