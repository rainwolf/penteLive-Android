<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingLeft="10dp"
    android:paddingRight="10dp"
    android:paddingBottom="10dp"
    android:paddingTop="10dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="45dp"
        android:gravity="center"
        android:textAppearance="?android:attr/textAppearanceMedium"
        android:text="challenge"
        android:textAlignment="center"
        android:id="@+id/titleLabel"
        android:layout_alignParentLeft="true"
        android:layout_alignParentStart="true" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="45dp"
        android:gravity="center_vertical"
        android:textAppearance="?android:attr/textAppearanceMedium"
        android:text="@string/days_per_move"
        android:textStyle="bold"
        android:id="@+id/timeoutLabel"
        android:layout_below="@id/titleLabel"
        android:layout_alignParentLeft="true"
        android:layout_alignParentStart="true" />
    <androidx.appcompat.widget.AppCompatSpinner
        android:spinnerMode="dialog"
        android:id="@+id/timeoutSpinner"
        android:layout_toRightOf="@id/timeoutLabel"
        android:textAppearance="?android:attr/textAppearanceLarge"
        android:layout_below="@id/titleLabel"
        android:layout_width="match_parent"
        android:textAlignment="center"
        android:layout_height="45dp"
        android:gravity="center_vertical">
    </androidx.appcompat.widget.AppCompatSpinner>
    <LinearLayout
        android:id="@+id/restrictionLayout"
        android:layout_width="match_parent"
        android:layout_height="45dp"
        android:layout_alignWithParentIfMissing="true"
        android:layout_below="@id/timeoutLabel"
        android:orientation="horizontal"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="45dp"
            android:gravity="center_vertical"
            android:textAppearance="?android:attr/textAppearanceMedium"
            android:text="@string/to_players"
            android:textStyle="bold"
            android:id="@+id/restrictionLabel"
            android:layout_alignParentLeft="true"
            android:layout_alignParentStart="true" />
        <androidx.appcompat.widget.AppCompatSpinner
            android:spinnerMode="dialog"
            android:id="@+id/restrictionSpinner"
            android:layout_toRightOf="@id/restrictionLabel"
            android:textAppearance="?android:attr/textAppearanceLarge"
            android:layout_width="match_parent"
            android:textAlignment="center"
            android:layout_height="45dp"
            android:gravity="center_vertical">
        </androidx.appcompat.widget.AppCompatSpinner>
    </LinearLayout>

    <Button
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/restrictionLayout"
        android:id="@+id/sendChallengeButton"
        android:text="@string/send_challenge"/>


</RelativeLayout>