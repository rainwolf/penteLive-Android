<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:ads="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    tools:context="be.submanifold.pentelive.BoardActivity">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="?attr/colorPrimary"
        android:theme="@style/ThemeOverlay.AppCompat.ActionBar"
        app:popupTheme="@style/ThemeOverlay.AppCompat.Light"/>
    <view
        class="be.submanifold.pentelive.BoardView"
        android:id="@+id/boardView"
        android:layout_below="@id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <LinearLayout
        android:id="@+id/submitLayout"
        android:layout_width="match_parent"
        android:orientation="horizontal"
        android:layout_below="@id/boardView"
        android:layout_height="wrap_content">
        <Button
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:focusable="false"
            android:drawableStart="@drawable/ic_skip_previous"
            android:textStyle="bold"
            android:id="@+id/backButton" />
        <Button
            android:layout_width="0dp"
            android:layout_weight="3"
            android:layout_height="wrap_content"
            android:focusable="false"
            android:text="@string/submit"
            android:textStyle="bold"
            android:id="@+id/submitButton" />
        <Button
            android:layout_width="0dp"
            android:layout_weight="3"
            android:layout_height="wrap_content"
            android:focusable="false"
            android:drawableStart="@drawable/databasesmall"
            android:text="@string/search"
            android:visibility="gone"
            android:textStyle="bold"
            android:id="@+id/searchDBbutton" />
        <Button
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:focusable="false"
            android:drawableEnd="@drawable/ic_skip_next"
            android:textStyle="bold"
            android:id="@+id/forwardButton" />
    </LinearLayout>
    <LinearLayout
        android:id="@+id/dPenteLayout"
        android:layout_width="match_parent"
        android:visibility="gone"
        android:orientation="horizontal"
        android:layout_below="@id/boardView"
        android:layout_height="wrap_content">

        <TextView
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_marginLeft="10dp"
            android:textSize="18dp"
            android:layout_height="wrap_content"
            android:textStyle="bold"
            android:text="@string/play_as"/>
        <Button
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="@string/white"
            android:focusable="false"
            android:textStyle="bold"
            android:id="@+id/playAsWhiteButton" />
        <Button
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:focusable="false"
            android:text="@string/black"
            android:textStyle="bold"
            android:id="@+id/playAsBlackButton" />
        <Button
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:focusable="false"
            android:text="@string/pass"
            android:textStyle="bold"
            android:id="@+id/swap2PassButton" />
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:id="@+id/playerInfo"
        android:layout_marginLeft="5dp"
        android:gravity="bottom|center"
        android:layout_marginRight="5dp"
        android:layout_marginBottom="3dp"
        android:paddingLeft="5dp"
        android:paddingRight="5dp"
        android:paddingTop="3dp"
        android:paddingBottom="3dp"
        android:textSize="16dp"
        android:layout_height="fill_parent"
        android:background="@drawable/border"
        android:layout_below="@id/submitLayout"/>



</RelativeLayout>
