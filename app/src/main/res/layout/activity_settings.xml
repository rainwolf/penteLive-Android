<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:paddingBottom="@dimen/activity_vertical_margin"
    android:paddingLeft="@dimen/activity_horizontal_margin"
    android:paddingRight="@dimen/activity_horizontal_margin"
    tools:context="be.submanifold.pentelive.SettingsActivity">

    <android.support.v7.widget.Toolbar
        android:id="@+id/my_toolbar"
        android:layout_width="match_parent"
        android:layout_alignParentTop="true"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/britishracinggreen"
        android:theme="@style/ThemeOverlay.AppCompat.ActionBar"
        app:popupTheme="@style/ThemeOverlay.AppCompat.Light"/>

    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/my_toolbar">
        <RelativeLayout
            android:id="@+id/scrollLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="45dp"
                android:gravity="center_vertical"
                android:textAppearance="?android:attr/textAppearanceMedium"
                android:text="@string/show_tb_only"
                android:textStyle="bold"
                android:id="@+id/tbOnlyLabel"
                android:layout_alignParentLeft="true"
                android:layout_alignParentStart="true" />
            <ToggleButton
                android:layout_width="wrap_content"
                android:layout_height="45dp"
                android:background="@android:color/transparent"
                android:checked="false"
                android:textOn="@string/yes"
                android:textOff="@string/no"
                android:id="@+id/tbOnlyToggleButton"
                android:layout_alignParentRight="true"
                android:layout_alignParentEnd="true" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="45dp"
                android:gravity="center_vertical"
                android:textAppearance="?android:attr/textAppearanceMedium"
                android:text="@string/load_avatars"
                android:textStyle="bold"
                android:id="@+id/avatarLabel"
                android:layout_below="@id/tbOnlyLabel"
                android:layout_alignParentLeft="true"
                android:layout_alignParentStart="true" />
            <ToggleButton
                android:layout_width="wrap_content"
                android:layout_height="45dp"
                android:background="@android:color/transparent"
                android:checked="false"
                android:textOn="@string/yes"
                android:textOff="@string/no"
                android:id="@+id/avatarToggleButton"
                android:layout_below="@id/tbOnlyToggleButton"
                android:layout_alignParentRight="true"
                android:layout_alignParentEnd="true" />
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="45dp"
        android:textSize="15dp"
        android:layout_marginBottom="10dp"
        android:gravity="center_vertical"
        android:textAppearance="?android:attr/textAppearanceMedium"
        android:text="@string/avatar_warning"
        android:id="@+id/infoLabel"
        android:layout_below="@id/avatarLabel"
        android:layout_alignParentLeft="true"
        android:layout_alignParentStart="true" />
    <Button
        android:layout_width="match_parent"
        android:id="@+id/preferencesButton"
        android:layout_height="wrap_content"
        android:layout_below="@id/infoLabel"
        android:text="@string/preferences_at_pente_org"
        android:layout_marginTop="5dp"/>
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="45dp"
        android:textSize="15dp"
        android:gravity="center_vertical"
        android:textAppearance="?android:attr/textAppearanceMedium"
        android:text="@string/more_prefs_label"
        android:id="@+id/infoLabel2"
        android:layout_below="@id/preferencesButton"
        android:layout_alignParentLeft="true"
        android:layout_alignParentStart="true"
        android:layout_marginBottom="20dp"/>
    <Button
        android:layout_width="match_parent"
        android:id="@+id/colorButton"
        android:layout_height="wrap_content"
        android:layout_below="@id/infoLabel2"
        android:text="@string/change_color"
        android:layout_marginTop="5dp"/>
    <Button
        android:layout_width="match_parent"
        android:id="@+id/avatarButton"
        android:layout_height="wrap_content"
        android:layout_below="@id/colorButton"
        android:text="@string/change_avatar"
        android:layout_marginTop="5dp"/>
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="45dp"
        android:textSize="15dp"
        android:gravity="center_vertical"
        android:textAppearance="?android:attr/textAppearanceMedium"
        android:text="@string/subscribers_only"
        android:id="@+id/infoLabel3"
        android:layout_below="@id/avatarButton"
        android:layout_alignParentLeft="true"
        android:layout_alignParentStart="true"
        android:layout_marginBottom="20dp"/>

    <ImageView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:id="@+id/avatarView"
        android:layout_below="@id/avatarButton"/>
    <Button
        android:layout_width="match_parent"
        android:id="@+id/subscribeButton"
        android:layout_height="wrap_content"
        android:layout_below="@id/infoLabel3"
        android:text="@string/subscribe_pente_org"
        android:layout_marginTop="5dp"/>
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="15dp"
        android:gravity="center_vertical"
        android:textAppearance="?android:attr/textAppearanceMedium"
        android:text="@string/subscribe_info"
        android:id="@+id/infoLabel4"
        android:layout_below="@id/subscribeButton"
        android:layout_alignParentLeft="true"
        android:layout_alignParentStart="true"
        android:layout_marginBottom="20dp"/>

    </RelativeLayout>
    </ScrollView>

</RelativeLayout>
