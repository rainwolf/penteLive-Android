<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/dashboardRow"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <ImageView
        android:id="@+id/imageView"
        android:layout_alignParentTop="true"
        android:src="@drawable/ic_action_lock_closed"
        android:layout_width="30dp"
        android:layout_alignParentRight="true"
        android:layout_alignWithParentIfMissing="true"
        android:layout_height="30dp" />
    <TextView android:id="@+id/gameNameText"
        android:textSize="18sp"
        android:gravity="center_vertical"
        android:textColor="#000000"
        android:layout_toLeftOf="@id/imageView"
        android:textStyle="bold"
        android:layout_marginLeft="10dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

    <TextView android:id="@+id/seatsText"
        android:textSize="15sp"
        android:gravity="center_vertical"
        android:textColor="#000000"
        android:layout_below="@id/gameNameText"
        android:layout_marginLeft="10dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>
    <TextView android:id="@+id/settingsText"
        android:textSize="15sp"
        android:gravity="center_vertical"
        android:textColor="#000000"
        android:layout_below="@id/seatsText"
        android:layout_marginLeft="10dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>
    <TextView android:id="@+id/watchingText"
        android:textSize="15sp"
        android:gravity="center_vertical"
        android:textColor="#000000"
        android:layout_below="@id/settingsText"
        android:layout_marginLeft="10dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>
</RelativeLayout>
