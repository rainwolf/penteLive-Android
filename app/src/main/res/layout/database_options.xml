<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingLeft="10dp"
    android:paddingRight="10dp"
    android:paddingBottom="10dp"
    android:paddingTop="10dp">
    <ScrollView
        android:id="@+id/scrollView"
        android:measureAllChildren="true"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <RelativeLayout
            android:id="@+id/scrollLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="45dp"
        android:gravity="center_vertical"
        android:textAppearance="?android:attr/textAppearanceMedium"
        android:text="@string/game"
        android:textStyle="bold"
        android:id="@+id/gameLabel"
        android:layout_alignParentLeft="true" />
    <android.support.v7.widget.AppCompatSpinner
        android:spinnerMode="dialog"
        android:id="@+id/gameSpinner"
        android:layout_toRightOf="@id/gameLabel"
        android:textAppearance="?android:attr/textAppearanceLarge"
        android:layout_width="match_parent"
        android:textAlignment="center"
        android:layout_height="45dp"
        android:gravity="center_vertical">
    </android.support.v7.widget.AppCompatSpinner>


    <TextView
        android:layout_width="wrap_content"
        android:layout_height="45dp"
        android:gravity="center_vertical"
        android:textAppearance="?android:attr/textAppearanceMedium"
        android:text="@string/sort_by"
        android:textStyle="bold"
        android:id="@+id/sortLabel"
        android:layout_below="@id/gameLabel"
        android:layout_alignParentLeft="true" />
    <TextView
        android:layout_width="match_parent"
        android:layout_height="45dp"
        android:gravity="center_vertical"
        android:onClick="onClick"
        android:clickable="true"
        android:layout_toRightOf="@id/sortLabel"
        android:textAlignment="center"
        android:textAppearance="?android:attr/textAppearanceMedium"
        android:text="@string/popularity"
        android:layout_below="@id/gameSpinner"
        android:id="@+id/sortChoice"
        android:layout_alignParentRight="true" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="45dp"
        android:gravity="center_vertical"
        android:textAppearance="?android:attr/textAppearanceMedium"
        android:text="@string/player1_label"
        android:textStyle="bold"
        android:id="@+id/player1Label"
        android:layout_below="@id/sortLabel"
        android:layout_alignParentLeft="true" />
    <AutoCompleteTextView
        android:id="@+id/player1"
        android:layout_width="match_parent"
        android:layout_below="@id/sortChoice"
        android:layout_toRightOf="@id/player1Label"
        android:textAlignment="center"
        android:layout_height="45dp"
        android:gravity="center_vertical" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="45dp"
        android:gravity="center_vertical"
        android:textAppearance="?android:attr/textAppearanceMedium"
        android:text="@string/player2_label"
        android:textStyle="bold"
        android:id="@+id/player2Label"
        android:layout_below="@id/player1Label"
        android:layout_alignParentLeft="true" />
    <AutoCompleteTextView
        android:id="@+id/player2"
        android:layout_width="match_parent"
        android:layout_below="@id/player1"
        android:textAlignment="center"
        android:layout_toRightOf="@id/player2Label"
        android:layout_height="45dp"
        android:gravity="center_vertical" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="45dp"
        android:gravity="center_vertical"
        android:textAppearance="?android:attr/textAppearanceMedium"
        android:text="@string/winner"
        android:textStyle="bold"
        android:id="@+id/winnerLabel"
        android:layout_below="@id/player2Label"
        android:layout_alignParentLeft="true" />
    <TextView
        android:layout_width="match_parent"
        android:layout_height="45dp"
        android:gravity="center_vertical"
        android:onClick="onClick"
        android:clickable="true"
        android:layout_toRightOf="@id/winnerLabel"
        android:textAlignment="center"
        android:textAppearance="?android:attr/textAppearanceMedium"
        android:text="@string/either"
        android:layout_below="@id/player2"
        android:id="@+id/winner"
        android:layout_alignParentRight="true" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="45dp"
        android:gravity="center_vertical"
        android:textAppearance="?android:attr/textAppearanceMedium"
        android:text="@string/after"
        android:textStyle="bold"
        android:id="@+id/afterLabel"
        android:layout_below="@id/winnerLabel"
        android:layout_alignParentLeft="true" />
    <TextView
        android:layout_width="match_parent"
        android:layout_height="45dp"
        android:gravity="center_vertical"
        android:onClick="onClick"
        android:clickable="true"
        android:textAlignment="center"
        android:textAppearance="?android:attr/textAppearanceMedium"
        android:layout_below="@id/winner"
        android:hint="@string/tap_to_set"
        android:layout_toRightOf="@id/afterLabel"
        android:id="@+id/afterDate"
        android:layout_alignParentRight="true" />
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="45dp"
        android:gravity="center_vertical"
        android:textAppearance="?android:attr/textAppearanceMedium"
        android:text="@string/before"
        android:textStyle="bold"
        android:id="@+id/beforeLabel"
        android:layout_below="@id/afterLabel"
        android:layout_alignParentLeft="true" />
    <TextView
        android:layout_width="match_parent"
        android:layout_height="45dp"
        android:gravity="center_vertical"
        android:onClick="onClick"
        android:clickable="true"
        android:textAlignment="center"
        android:hint="@string/tap_to_set"
        android:textAppearance="?android:attr/textAppearanceMedium"
        android:layout_below="@id/afterDate"
        android:layout_toRightOf="@id/beforeLabel"
        android:id="@+id/beforeDate"
        android:layout_alignParentRight="true" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="45dp"
                android:gravity="center_vertical"
                android:textAppearance="?android:attr/textAppearanceMedium"
                android:text="@string/p1_rating_above"
                android:textStyle="bold"
                android:id="@+id/p1RatingLabel"
                android:layout_below="@id/beforeLabel"
                android:layout_alignParentLeft="true" />
            <android.support.v7.widget.AppCompatSpinner
                android:spinnerMode="dialog"
                android:id="@+id/p1RatingSpinner"
                android:layout_toRightOf="@id/p1RatingLabel"
                android:layout_below="@id/beforeDate"
                android:textAppearance="?android:attr/textAppearanceLarge"
                android:layout_width="match_parent"
                android:textAlignment="center"
                android:layout_height="45dp"
                android:gravity="center_vertical">
            </android.support.v7.widget.AppCompatSpinner>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="45dp"
                android:gravity="center_vertical"
                android:textAppearance="?android:attr/textAppearanceMedium"
                android:text="@string/p2_rating_above"
                android:textStyle="bold"
                android:id="@+id/p2RatingLabel"
                android:layout_below="@id/p1RatingLabel"
                android:layout_alignParentLeft="true" />
            <android.support.v7.widget.AppCompatSpinner
                android:spinnerMode="dialog"
                android:id="@+id/p2RatingSpinner"
                android:layout_toRightOf="@id/p2RatingLabel"
                android:layout_below="@id/p1RatingSpinner"
                android:textAppearance="?android:attr/textAppearanceLarge"
                android:layout_width="match_parent"
                android:textAlignment="center"
                android:layout_height="45dp"
                android:gravity="center_vertical">
            </android.support.v7.widget.AppCompatSpinner>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="45dp"
                android:gravity="center_vertical"
                android:textAppearance="?android:attr/textAppearanceMedium"
                android:text="@string/match_players"
                android:textStyle="bold"
                android:id="@+id/eitherOrBothLabel"
                android:layout_below="@id/p2RatingLabel"
                android:layout_alignParentLeft="true" />
            <TextView
                android:layout_width="match_parent"
                android:layout_height="45dp"
                android:gravity="center_vertical"
                android:onClick="onClick"
                android:clickable="true"
                android:layout_toRightOf="@id/eitherOrBothLabel"
                android:textAlignment="center"
                android:textAppearance="?android:attr/textAppearanceMedium"
                android:text="@string/both"
                android:layout_below="@id/p2RatingSpinner"
                android:id="@+id/eitherOrBoth"
                android:layout_alignParentRight="true" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="45dp"
                android:gravity="center_vertical"
                android:textAppearance="?android:attr/textAppearanceMedium"
                android:text="@string/exclude_timeouts"
                android:textStyle="bold"
                android:id="@+id/excludeTimeoutsLabel"
                android:layout_below="@id/eitherOrBothLabel"
                android:layout_alignParentLeft="true" />
            <TextView
                android:layout_width="match_parent"
                android:layout_height="45dp"
                android:gravity="center_vertical"
                android:onClick="onClick"
                android:clickable="true"
                android:layout_toRightOf="@id/excludeTimeoutsLabel"
                android:textAlignment="center"
                android:textAppearance="?android:attr/textAppearanceMedium"
                android:text="@string/no"
                android:layout_below="@id/eitherOrBoth"
                android:id="@+id/excludeTimeouts"
                android:layout_alignParentRight="true" />
        </RelativeLayout>
    </ScrollView>
</RelativeLayout>